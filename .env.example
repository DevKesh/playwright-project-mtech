# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Runtime Configuration — LOCAL vs CI/CD                                     ║
# ║  Copy this file to .env and adjust values for your local setup.             ║
# ║  .env is gitignored — your local settings won't be committed.               ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Execution Mode ──────────────────────────────────────────────────────────
# Auto-detected from CI env var. Force override:
# RUN_MODE=local          # 'local' | 'ci'

# ─── Browser Settings ────────────────────────────────────────────────────────
HEADLESS=false            # true = headless, false = see the browser
BROWSER_CHANNEL=chrome    # chrome | msedge | chromium
SLOW_MO=0                 # Milliseconds delay between actions (debug aid)

# ─── Reporting ───────────────────────────────────────────────────────────────
OPEN_REPORT=true          # Auto-open Allure report after run
SLACK_ENABLED=false       # Send Slack notifications locally? Usually no.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxxx

# ─── Credentials ─────────────────────────────────────────────────────────────
# Leave commented to use hardcoded defaults, or set to override:
# TC_USERNAME=tmsqa@1
# TC_PASSWORD=Password@3
# TC_DISPLAY_NAME=Keshav QA_Testt

# ─── AI Healing ──────────────────────────────────────────────────────────────
AI_HEALING_ENABLED=false  # Enable AI self-healing on test failures
OPENAI_API_KEY=your-key-here
AI_HEALING_MODEL=gpt-4o-mini
AI_ANALYSIS_MODEL=gpt-4o
AI_HEALING_MAX_RETRIES=2
AI_HEALING_CONFIDENCE_THRESHOLD=0.7

# ─── Timeouts (ms) ──────────────────────────────────────────────────────────
NAV_TIMEOUT=15000         # Page navigation timeout
ACTION_TIMEOUT=10000      # Click/fill/etc timeout
TEST_TIMEOUT=60000        # Individual test timeout

# ─── LambdaTest Cloud Execution ──────────────────────────────────────────────
# Set EXECUTION_PLATFORM=lambda to run tests on LambdaTest cloud.
# Default is 'local' — tests run on your machine as usual.
EXECUTION_PLATFORM=local          # 'local' | 'lambda'

# LambdaTest credentials (required when EXECUTION_PLATFORM=lambda)
LT_USERNAME=
LT_ACCESS_KEY=

# Build & project identification (visible on LambdaTest dashboard)
# LT_BUILD_NAME=TC2-2026-05-21        # Defaults to TC2-<date>
# LT_PROJECT_NAME=TC2-Automation      # Groups runs on dashboard

# Browser configuration on LambdaTest
# LT_BROWSER=Chrome                   # Chrome | MicrosoftEdge | pw-firefox | pw-webkit
# LT_BROWSER_VERSION=latest           # 'latest' or specific version
# LT_PLATFORM=Windows 11              # Windows 11 | macOS Sonoma | etc.
# LT_RESOLUTION=1920x1080             # Screen resolution

# Recording & debugging (all enabled by default)
LT_VIDEO=true                         # Record video of test execution
LT_CONSOLE=true                       # Capture browser console logs
LT_NETWORK=true                       # Capture network requests

# LambdaTest Tunnel (for testing internal/private apps)
LT_TUNNEL=false                       # Set true if QA app is behind firewall
# LT_TUNNEL_NAME=my-tunnel            # Named tunnel identifier
