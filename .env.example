# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Runtime Configuration — LOCAL vs CI/CD                                     ║
# ║  Copy this file to .env and adjust values for your local setup.             ║
# ║  .env is gitignored — your local settings won't be committed.               ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Execution Mode ──────────────────────────────────────────────────────────
# Auto-detected from CI env var. Force override:
# RUN_MODE=local          # 'local' | 'ci'

# ─── Browser Settings ────────────────────────────────────────────────────────
HEADLESS=false            # true = headless, false = see the browser
BROWSER_CHANNEL=chrome    # chrome | msedge | chromium
SLOW_MO=0                 # Milliseconds delay between actions (debug aid)

# ─── Reporting ───────────────────────────────────────────────────────────────
OPEN_REPORT=true          # Auto-open Allure report after run
SLACK_ENABLED=false       # Send Slack notifications locally? Usually no.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxxx

# ─── Credentials ─────────────────────────────────────────────────────────────
# Leave commented to use hardcoded defaults, or set to override:
# TC_USERNAME=tmsqa@1
# TC_PASSWORD=Password@3
# TC_DISPLAY_NAME=Keshav QA_Testt

# ─── AI Healing ──────────────────────────────────────────────────────────────
AI_HEALING_ENABLED=false  # Enable AI self-healing on test failures
OPENAI_API_KEY=your-key-here
AI_HEALING_MODEL=gpt-4o-mini
AI_ANALYSIS_MODEL=gpt-4o
AI_HEALING_MAX_RETRIES=2
AI_HEALING_CONFIDENCE_THRESHOLD=0.7

# ─── Timeouts (ms) ──────────────────────────────────────────────────────────
NAV_TIMEOUT=15000         # Page navigation timeout
ACTION_TIMEOUT=10000      # Click/fill/etc timeout
TEST_TIMEOUT=60000        # Individual test timeout
