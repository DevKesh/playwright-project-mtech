    "armHomeButton": {
      "selector": "page.locator('button', { hasText: 'ARM HOME' }).first()",
      "type": "button",
      "action": "click",
      "context": "Arms perimeter sensors. IMPORTANT: (1) aria-label overrides accessible name so getByRole FAILS. (2) getByText matches multiple elements (per-partition buttons). MUST USE page.locator('button', { hasText: 'ARM HOME' }).first()",
      "visibleAfter": "selectAllCheckbox"
    },
    "armAwayButton": {
      "selector": "page.locator('button', { hasText: 'ARM AWAY' }).first()",
